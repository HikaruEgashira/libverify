+                    .filter(|r| r["level"].as_str() != /* ~ changed by cargo-mutants ~ */ Some("error"))
                     .cloned()
                     .collect();
                 run["results"] = serde_json::Value::Array(filtered);
             }
         }
     }
 }
 
